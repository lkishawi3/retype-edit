{
    "name": "retype",
    "repository": {
        "type": "git",
        "url": "https://github.com/Nirmiti0826/retype.git"
    },
    "displayName": "ReType",
    "description": "Transform code editing into typing practice - like MonkeyType for programming",
    "version": "1.0.0",
    "publisher": "Nirmiti",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Other",
        "Education"
    ],
    "icon": "images/icon.png",
    "keywords": [
        "typing",
        "practice",
        "monkeytype",
        "programming",
        "education"
    ],
    "activationEvents": [
        "onCommand:retype.startPractice",
        "onCommand:retype.stopPractice",
        "onCommand:retype.togglePractice",
        "onCommand:retype.resetSession",
        "onCommand:retype.configureKeybinds",
        "onCommand:retype.pasteAndPractice",
        "onView:retypeSettingsView"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "retype-explorer",
                    "title": "ReType",
                    "icon": "images/icon.png"
                }
            ]
        },
        "views": {
            "retype-explorer": [
                {
                    "id": "retypeSettingsView",
                    "name": "ReType Settings",
                    "type": "webview"
                }
            ]
        },
        "commands": [
            {
                "command": "retype.startPractice",
                "title": "Start Practice Mode",
                "category": "ReType"
            },
            {
                "command": "retype.togglePractice",
                "title": "Toggle Practice Mode",
                "category": "ReType"
            },
            {
                "command": "retype.stopPractice",
                "title": "Stop Practice Mode",
                "category": "ReType"
            },
            {
                "command": "retype.resetSession",
                "title": "Reset Current Session",
                "category": "ReType"
            },
            {
                "command": "retype.configureKeybinds",
                "title": "Configure ReType Keybinds",
                "category": "ReType"
            },
            {
                "command": "retype.openSettings",
                "title": "Open Settings",
                "category": "ReType"
            },
            {
                "command": "retype.pasteAndPractice",
                "title": "Paste & Practice",
                "category": "ReType"
            }
        ],
        "keybindings": [
            {
                "command": "retype.togglePractice",
                "key": "ctrl+`",
                "mac": "cmd+`"
            },
            {
                "command": "retype.pasteAndPractice",
                "key": "ctrl+shift+v",
                "mac": "cmd+shift+v",
                "when": "editorTextFocus"
            }
        ],
        "configuration": {
            "title": "ReType",
            "properties": {
                "retype.theme": {
                    "type": "string",
                    "default": "solarized-light",
                    "description": "Color theme for typing practice",
                    "enum": [
                        "solarized-light"
                    ]
                },
                "retype.showRealTimeStats": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show real-time typing statistics in status bar"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@types/node": "16.x",
        "typescript": "^4.9.4"
    },
    "license": "MIT"
}
